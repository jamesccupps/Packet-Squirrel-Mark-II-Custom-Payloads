#!/bin/bash
# Title:        Chaos Engine (Level 2: The Lag Switch)
# Description:  Injects a horrible 250ms delay and 2% jitter into the connection.
# Net Mode:     BRIDGE

function run_chaos() {
    NETMODE BRIDGE
    sleep 10
    
    # Clear existing rules
    tc qdisc del dev br-lan root 2>/dev/null
    
    # Inject a 250ms delay, with a random +/- 50ms jitter to make it unpredictable
    tc qdisc add dev br-lan root netem delay 250ms 50ms
    
    # Solid Red LED so you know the chaos is active
    LED R SOLID
}

USB_WAIT
run_chaos &
wait
