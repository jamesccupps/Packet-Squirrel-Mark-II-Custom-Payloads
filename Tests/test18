#!/bin/bash
# Title:        Printer Auditor
# Description:  Monitors local MQTT/FTP and flags outbound cloud attempts.
# Net Mode:     BRIDGE

function run_printer_auditor() {
    NETMODE BRIDGE
    mkdir -p /usb/loot/printer &> /dev/null
    sleep 10
    LED SETUP

    # Capture secure MQTT (8883) and FTP (21, 990) used by modern local-mode printers
    tcpdump -i br-lan tcp port 8883 or port 21 or port 990 -w /usb/loot/printer/gcode_traffic.pcap &>/dev/null &
    
    # Simultaneously monitor for rogue DNS requests (trying to find cloud servers)
    tcpdump -l -i br-lan udp port 53 2>/dev/null | grep --line-buffered "bambulab\|cloud" > /usb/loot/printer/rogue_dns_alerts.txt &
    
    NO_LED=true BUTTON
    killall tcpdump
    sync
    LED G SUCCESS
}

USB_WAIT
run_printer_auditor &
