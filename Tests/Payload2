#!/bin/bash
# 
# Title:        Hybrid Stealth Mapper
# Description:  Fast ping sweep with active MAC spoofing and decoy evasion. Stays online.
# Author:       Hak5 / Modified Hybrid
# Net Mode:     BRIDGE

# ============================================================================
# HOW TO ACCESS YOUR LOOT:
# 1. SSH into the IP found in /usb/loot/squirrel_ip.txt
# 2. View the scan: cat /usb/loot/nmap/hybrid_scan_*.txt
# ============================================================================

function run_hybrid_mapper() {
    # 1. Set to Bridge mode and wait for an IP from the router
    NETMODE BRIDGE
    sleep 10

    # 2. Setup the loot directories
    mkdir -p /usb/loot/nmap &> /dev/null

    # 3. Log the dynamically assigned IP to the USB drive (Sneakernet feature)
    ip addr show br-lan | grep -w inet | awk '{print $2}' | cut -d/ -f1 > /usb/loot/squirrel_ip.txt

    # Indicate the setup phase (Blinking Yellow)
    LED SETUP

    # 4. Dynamically figure out the local subnet
    SUBNET=$(ip route | grep br-lan | grep -v default | awk '{print $1}')

    # 5. Execute the Hybrid Scan
    if [ ! -z "$SUBNET" ]; then
        # Indicate active scanning (Solid Red)
        LED ATTACK
        
        # THE HYBRID COMMAND:
        # -sn             : Fast Ping Sweep only (No slow port scanning)
        # --spoof-mac     : Masquerade as a Cisco hardware device
        # -D RND:5        : Generate 5 random decoy IP addresses to mask your real IP
        # --randomize-hosts: Ping IPs out of order to evade sequential detection rules
        # -oN             : Output to a clean text file
        nmap -sn "$SUBNET" --spoof-mac Cisco -D RND:5 --randomize-hosts -oN /usb/loot/nmap/hybrid_scan_$(date +%Y-%m-%d-%H%M%S).txt &> /dev/null
        
        # Scan complete (Solid Green)
        LED G SUCCESS
    else
        # Failed to get an IP or Subnet (Blinking Red)
        LED FAIL
    fi
}

# Wait for the USB drive to mount
USB_WAIT

# Start the routine
run_hybrid_mapper &
wait
