#!/bin/bash
# Title:        Silent Subnet Mapper
# Description:  Gets an IP, calculates the subnet, runs Nmap, and saves to USB.
# Net Mode:     BRIDGE

function run_mapper() {
    # 1. Set to Bridge mode and wait for an IP from the router
    NETMODE BRIDGE
    sleep 10

    # Create the loot directory
    mkdir -p /usb/loot/nmap &> /dev/null

    # Indicate the scan is starting (Blinking Yellow)
    LED SETUP

    # 2. Dynamically figure out the local subnet (e.g., 192.168.1.0/24)
    # This grabs the IP route for the bridge interface and extracts the subnet notation
    SUBNET=$(ip route | grep br-lan | grep -v default | awk '{print $1}')

    # 3. If we successfully grabbed a subnet, run Nmap
    if [ ! -z "$SUBNET" ]; then
        # Indicate active scanning (Solid Red)
        LED ATTACK
        
        # Run a ping sweep (-sn) and output to a normal text file (-oN)
        nmap -sn "$SUBNET" -oN /usb/loot/nmap/scan_$(date +%Y-%m-%d-%H%M%S).txt &> /dev/null
        
        # Scan complete (Solid Green)
        LED G SUCCESS
    else
        # Failed to get an IP or Subnet (Blinking Red)
        LED FAIL
    fi
}

USB_WAIT
run_mapper &
wait
