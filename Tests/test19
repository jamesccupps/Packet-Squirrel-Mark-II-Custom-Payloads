#!/bin/bash
# Title:        API Panic Button
# Description:  Fires a webhook to Home Assistant on button press.
# Net Mode:     BRIDGE

# Define your local Home Assistant webhook URL here
HA_WEBHOOK="http://192.168.1.XXX:8123/api/webhook/your_secret_webhook_id"

function run_api_button() {
    NETMODE BRIDGE
    sleep 10
    
    # Wait in an armed state
    while true; do
        LED SETUP
        
        # Wait for the user to physically push the button
        NO_LED=true BUTTON
        LED ATTACK
        
        # Fire the webhook payload
        curl -X POST "$HA_WEBHOOK" -H "Content-Type: application/json" -d '{"source": "packet_squirrel", "action": "panic_button_pressed"}' &>/dev/null
        
        # Flash success and reset for the next press
        LED G SUCCESS
        sleep 2
    done
}

run_api_button &
