#!/bin/bash
# Title:        IoT Quarantine
# Description:  Allows local LAN traffic but strictly drops all WAN (Internet) outbound traffic.
# Net Mode:     BRIDGE

function run_quarantine() {
    NETMODE BRIDGE
    sleep 5
    LED SETUP

    # Flush existing firewall rules
    iptables -F FORWARD

    # Allow local traffic (Subnet to Subnet)
    # Assuming standard 192.168.x.x or 10.x.x.x private IP ranges
    iptables -A FORWARD -d 192.168.0.0/16 -j ACCEPT
    iptables -A FORWARD -d 10.0.0.0/8 -j ACCEPT
    iptables -A FORWARD -d 172.16.0.0/12 -j ACCEPT

    # Drop everything else trying to leave the bridge (Internet traffic)
    iptables -A FORWARD -j DROP

    # Indicate the physical firewall is active
    LED C SUCCESS
    
    # Button press to lift the quarantine
    NO_LED=true BUTTON
    iptables -F FORWARD
    LED G SUCCESS
}

USB_WAIT
run_quarantine &
